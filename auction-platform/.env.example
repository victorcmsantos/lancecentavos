# Host ports (avoid conflicts with common defaults)
POSTGRES_PORT=15432
REDIS_PORT=16379
BACKEND_PORT=18080
FRONTEND_PORT=13000

# Postgres (container env)
POSTGRES_DB=auction
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend (container env)
BACKEND_LISTEN_PORT=8080
DATABASE_URL=postgres://postgres:postgres@postgres:5432/auction?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
JWT_SECRET=replace-with-strong-secret
JWT_ISSUER=auction-platform
JWT_EXPIRY_MINUTES=60
CORS_ORIGIN=http://localhost:13000
BID_COUNTDOWN_SECONDS=3600

# Bootstrap admin user (created on first run if no admin exists)
BOOTSTRAP_ADMIN_EMAIL=admin@local
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FORCE_RESET=false
BOOTSTRAP_ADMIN_OUTPUT_PATH=/bootstrap-admin/admin.json

# Frontend (container env / build-time defaults)
API_URL_INTERNAL=http://backend:8080/api/v1
NEXT_PUBLIC_API_URL=http://localhost:18080/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:18080
